# ============================================================================
#  Example environment configuration.
#  Copy this file to ".env" and fill in real values:   cp .env.example .env
#
#  WHY: secrets (like the database URL and session secret) should never be
#  committed to git. The real ".env" file is git-ignored; this ".env.example"
#  is the safe, shareable template that documents WHICH variables exist.
#
#  Locally, the app also has sensible defaults (see src/db.js and src/server.js),
#  so it can run even without a .env file — but setting them is good practice.
# ============================================================================

# The port the server listens on. Render sets this for you automatically.
PORT=3000

# How to reach Postgres. Format: postgres://USER:PASSWORD@HOST:PORT/DATABASE_NAME
# Local example below assumes a database named "htweeth" on your machine.
DATABASE_URL=postgres://localhost:5432/htweeth

# A long, random string used to sign login cookies so they can't be forged.
# Generate one with:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-me-with-a-long-random-string
